# Azure OpenAI embedding configuration
AZURE_EMBEDDER_API_KEY=your-azure-openai-api-key
AZURE_EMBEDDER_URL=https://your-resource.openai.azure.com/openai/v1/
AZURE_EMBEDDER_MODEL=text-embedding-3-small

# Qdrant configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional helper value used by smoke-test.py
QDRANT_COLLECTION=memory_chunks
